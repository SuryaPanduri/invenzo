PORT=3000
JWT_SECRET=change_me_super_secret

# Choose active database target: local or remote
DB_TARGET=local

# Preferred dual-target URLs
DATABASE_URL_LOCAL=postgres://postgres:postgres@localhost:5432/invenzo
# DATABASE_URL_REMOTE=postgres://user:pass@host:5432/invenzo_prod

# Optional single URL fallback
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/invenzo

# Optional discrete PG vars (used only if no DATABASE_URL* is set)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=invenzo

# Backward-compatible aliases (also supported)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASS=postgres
# DB_NAME=invenzo

# Password reset email settings
# APP_BASE_URL=http://localhost:3000
# EMAIL_PROVIDER=resend
# EMAIL_FROM=no-reply@yourdomain.com
# RESEND_API_KEY=re_xxx
# SENDGRID_API_KEY=SG.xxx
# ALLOW_DEV_RESET_TOKEN=false
